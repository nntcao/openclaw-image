{
  "$schema": "https://docs.openclaw.ai/config-schema.json",
  "version": "1.0",
  "persona": {
    "name": "Assistant",
    "description": "A human-esque personal AI assistant accessible via Telegram",
    "personality": {
      "tone": "warm, direct, and thoughtful",
      "style": "conversational but precise — like a capable colleague who remembers everything",
      "behaviors": [
        "proactively surfaces relevant context from memory before answering",
        "asks clarifying questions when intent is ambiguous rather than guessing",
        "provides concise answers by default, elaborates when asked",
        "remembers user preferences and adapts over time",
        "handles multi-step tasks autonomously and reports back"
      ]
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "configPath": "/home/openclaw/.openclaw/telegram.json"
    },
    "api": {
      "enabled": true,
      "port": 3000,
      "cors": false
    }
  },
  "models": {
    "routing": {
      "enabled": true,
      "strategy": "manifest",
      "tiers": {
        "free": {
          "model": "${ROUTE_FREE_MODEL}",
          "provider": "openrouter",
          "maxTokens": 8192,
          "cost": 0,
          "tasks": ["simple_qa", "formatting", "translation", "status_checks", "greetings", "small_talk", "lookup", "date_time", "unit_conversion", "yes_no"]
        },
        "cheap": {
          "model": "${ROUTE_CHEAP_MODEL}",
          "provider": "${ROUTE_CHEAP_PROVIDER}",
          "maxTokens": 8192,
          "tasks": ["tool_dispatch", "short_summarization", "classification", "extraction", "templating"]
        },
        "standard": {
          "model": "${ROUTE_STANDARD_MODEL}",
          "maxTokens": 16384,
          "tasks": ["code_generation", "analysis", "summarization", "planning", "multi_step"]
        },
        "heavy": {
          "model": "${ROUTE_HEAVY_MODEL}",
          "maxTokens": 65536,
          "tasks": ["complex_reasoning", "architecture", "debugging", "research", "creative"]
        }
      },
      "fallback": {
        "onFreeFailure": "cheap",
        "onFreeRateLimit": "cheap",
        "onCheapFailure": "standard"
      },
      "subAgentModel": "${ROUTE_SUBAGENT_MODEL}",
      "promptCaching": true
    },
    "providers": {
      "openrouter": {
        "type": "openai-compatible",
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKeyEnv": "OPENROUTER_API_KEY",
        "models": ["${ROUTE_FREE_MODEL}"]
      },
      "groq": {
        "type": "openai-compatible",
        "baseUrl": "https://api.groq.com/openai/v1",
        "apiKeyEnv": "GROQ_API_KEY",
        "models": ["${ROUTE_CHEAP_MODEL}"]
      },
      "anthropic": {
        "apiKeyEnv": "ANTHROPIC_API_KEY",
        "promptCaching": true
      },
      "openai": {
        "apiKeyEnv": "OPENAI_API_KEY"
      },
      "google": {
        "apiKeyEnv": "GOOGLE_API_KEY"
      }
    }
  },
  "memory": {
    "backend": "${MEMORY_BACKEND}",
    "persistPath": "/data/memory",
    "hyperspell": {
      "enabled": true,
      "apiKeyEnv": "HYPERSPELL_API_KEY",
      "syncInterval": "5m",
      "sources": ["conversations", "files", "calendar"]
    },
    "fallback": {
      "backend": "markdown",
      "path": "/data/memory/markdown"
    }
  },
  "context": {
    "losslessClaw": {
      "enabled": true,
      "dbPath": "/data/sqlite/lcm.db",
      "contextThreshold": 0.75,
      "freshTailCount": 32,
      "tools": ["lcm_grep", "lcm_describe", "lcm_expand"]
    }
  },
  "tracing": {
    "opik": {
      "enabled": true,
      "selfHosted": true,
      "project": "openclaw",
      "captureToolCalls": true,
      "captureTokenUsage": true,
      "captureLatency": true
    }
  },
  "security": {
    "ssh": {
      "enabled": true,
      "port": 22,
      "allowedAuthMethods": ["publickey"],
      "fido2": {
        "enabled": "${FIDO2_ENABLE}",
        "acceptedKeyTypes": [
          "sk-ssh-ed25519@openssh.com",
          "sk-ecdsa-sha2-nistp256@openssh.com"
        ]
      }
    },
    "rateLimit": {
      "enabled": true,
      "maxRequestsPerMinute": 60,
      "maxTokensPerHour": 1000000
    }
  },
  "cron": {
    "enabled": true,
    "jobsPath": "/home/openclaw/.openclaw/cron"
  },
  "plugins": {
    "configPath": "/home/openclaw/.openclaw/plugins.json"
  }
}
