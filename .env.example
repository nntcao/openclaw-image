# =============================================================================
# OpenClaw Docker Image - Environment Configuration
# Copy this to .env and fill in your values
# =============================================================================

# =============================================================================
# MODEL PROVIDERS & ROUTING
# =============================================================================
# The image routes requests through 4 cost tiers:
#   free ($0) → cheap ($0.11/M) → standard ($3/M) → heavy ($15/M)
# Most personal assistant tasks stay in the free/cheap tiers.
# Typical monthly cost: $5-15 for moderate daily use.

# --- Anthropic (standard + heavy tiers) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenRouter (free tier — 27+ free models including DeepSeek R1, Llama 3.3 70B) ---
# Sign up at https://openrouter.ai — free tier: 20 req/min, 200 req/day
OPENROUTER_API_KEY=sk-or-...

# --- Groq (cheap tier — blazing fast Llama inference) ---
# Sign up at https://console.groq.com — free tier available
GROQ_API_KEY=gsk_...

# --- Optional providers ---
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Model Routing ---
# 4 tiers: free → cheap → standard → heavy
# Free tier: OpenRouter free models ($0, rate-limited)
ROUTE_FREE_MODEL=deepseek/deepseek-r1:free
# Cheap tier: Groq fast inference ($0.11/M input tokens)
ROUTE_CHEAP_MODEL=llama-4-scout-17b-16e-instruct
ROUTE_CHEAP_PROVIDER=groq
# Standard tier: Claude Sonnet ($3/M input)
ROUTE_STANDARD_MODEL=claude-sonnet-4-6
# Heavy tier: Claude Opus ($15/M output) — only for complex reasoning
ROUTE_HEAVY_MODEL=claude-opus-4-6
# Sub-agent model: what spawned sub-agents use (keep cheap)
ROUTE_SUBAGENT_MODEL=claude-sonnet-4-6

# =============================================================================
# TELEGRAM BOT
# =============================================================================
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Comma-separated Telegram user IDs allowed to interact with the bot
# Get your ID from @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=123456789
# Leave blank — polling mode is default (no inbound ports needed)
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# =============================================================================
# INTEGRATIONS (all managed by Composio — one key for everything)
# =============================================================================
# This is the ONLY key you need for Gmail, Calendar, GitHub, Slack, Notion, etc.
# Composio handles all OAuth flows, token refresh, and rate limits.
# 1. Sign up at https://app.composio.dev
# 2. Get your API key
# 3. Connect your apps via the Composio dashboard (one OAuth click each)
# 4. That's it — no per-service API keys needed
COMPOSIO_API_KEY=

# --- Email (Gmail) — ONLY if not using Composio ---
# Option B (manual): Create a Gmail, generate App Password:
#   Google Account → Security → 2FA → App Passwords → generate for "Mail"
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# =============================================================================
# PLUGINS
# =============================================================================
# --- Lossless-Claw (context management) ---
LCM_ENABLED=true
LCM_CONTEXT_THRESHOLD=0.75
LCM_FRESH_TAIL_COUNT=32

# --- Hyperspell (knowledge graph memory) ---
# Get from https://hyperspell.com
HYPERSPELL_API_KEY=

# --- Foundry (Azure AI tool generation) ---
AZURE_AI_FOUNDRY_KEY=
AZURE_AI_FOUNDRY_ENDPOINT=

# --- Opik (tracing & observability) ---
# Leave empty for self-hosted, or set for Comet cloud
OPIK_API_KEY=
OPIK_WORKSPACE=default
OPIK_PROJECT_NAME=openclaw
OPIK_SELF_HOSTED=true

# =============================================================================
# SECURITY & NETWORKING
# =============================================================================
# --- Tailscale (Zero-Trust VPN) ---
# RECOMMENDED: Replaces exposed SSH port with private VPN access
# 1. Sign up at https://tailscale.com (free for personal use)
# 2. Go to Settings → Keys → Generate auth key (reusable, ephemeral)
# 3. Install Tailscale on your laptop/phone too
# 4. SSH in via: ssh openclaw@openclaw (no public ports needed)
TAILSCALE_AUTHKEY=
TAILSCALE_HOSTNAME=openclaw

# --- SSH ---
# If using Tailscale, you can disable public SSH entirely
SSH_ENABLE=true
SSH_KEYS_PATH=./ssh
FIDO2_ENABLE=false

# --- Caddy (Reverse Proxy / HTTPS) ---
# Only needed if you use webhook mode or want a public API endpoint
CADDY_ENABLE=false
DOMAIN=
ACME_EMAIL=


# =============================================================================
# INFRASTRUCTURE
# =============================================================================
# --- Timezone ---
# IMPORTANT: All proactive jobs (briefings, reminders) run in this timezone
TZ=America/New_York

# --- Backup ---
# Remote backup via rclone (e.g. "s3:mybucket/openclaw-backups")
BACKUP_REMOTE=
BACKUP_RETENTION_DAYS=30
BACKUP_NOTIFY=false

# --- Ports ---
HTTPS_PORT=443
HTTP_PORT=80
OPENCLAW_PORT=3000
SSH_PORT=2222
OPIK_PORT=5173

# --- Memory ---
MEMORY_BACKEND=hyperspell

# --- Misc ---
OPENCLAW_LOG_LEVEL=info
CONFIG_OVERRIDE_PATH=./config

# =============================================================================
# SPEND LIMITS (set these on provider dashboards!)
# =============================================================================
# Anthropic: console.anthropic.com → Settings → Limits → $25/month
# OpenAI: platform.openai.com → Settings → Limits → $10/month
# Groq: Free tier has built-in rate limits
# OpenRouter: Free tier has built-in rate limits (200 req/day)
