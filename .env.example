# =============================================================================
# OpenClaw Docker Image - Environment Configuration
# Copy this to .env and fill in your values
# =============================================================================

# --- Anthropic API Key (REQUIRED) ---
# OpenClaw uses Claude models via your Anthropic API key
# Set a spend limit at console.anthropic.com → Settings → Limits
ANTHROPIC_API_KEY=sk-ant-...

# --- Telegram Bot (REQUIRED) ---
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Get your ID from @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=123456789

# --- Timezone (REQUIRED) ---
# All proactive jobs (briefings, reminders) run in this timezone
TZ=America/New_York

# =============================================================================
# OPTIONAL
# =============================================================================

# --- Composio (managed integrations) ---
# One key for Gmail, Calendar, GitHub, Slack, Notion, etc.
# Sign up at https://app.composio.dev
COMPOSIO_API_KEY=

# --- Tailscale (zero-trust VPN) ---
# Replaces exposed SSH port with private VPN access
# Sign up at https://tailscale.com (free for personal use)
TAILSCALE_AUTHKEY=
TAILSCALE_HOSTNAME=openclaw

# --- Lossless-Claw (context management) ---
LCM_ENABLED=true

# --- SSH ---
SSH_ENABLE=true
SSH_KEYS_PATH=./ssh

# --- Backup ---
BACKUP_REMOTE=
BACKUP_RETENTION_DAYS=30
BACKUP_NOTIFY=false

# --- Caddy (HTTPS reverse proxy — only if you need a public endpoint) ---
CADDY_ENABLE=false
DOMAIN=
ACME_EMAIL=
